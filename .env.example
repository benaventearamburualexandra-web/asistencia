# CONFIGURACIÓN DE BASE DE DATOS (Obligatorio)
# Usa el puerto 6543 para Supabase en producción
DATABASE_URL="postgresql://postgres.[USUARIO]:[PASSWORD]@[HOST]:6543/postgres"


# CONFIGURACIÓN DE REPORTES POR CORREO (Opcional)
# Para que funcionen los reportes automáticos mensuales
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion-de-google"
ADMIN_EMAIL="correo-donde-llegan-los-reportes@gmail.com"

# NODE_ENV=development (Local) o production (Render)
NODE_ENV=development
